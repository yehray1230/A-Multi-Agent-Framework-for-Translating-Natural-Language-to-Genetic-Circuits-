from __future__ import annotations

import json

from schemas.state import CircuitState
from utils.llm_utils import call_llm


def call_design_consolidator(
    state: CircuitState,
    api_key: str | None,
    model_name: str,
    api_base: str | None = None,
) -> CircuitState:
    system_prompt = """You are Design Consolidator.

Turn the approved genetic circuit candidate and Critic feedback into a concise final specification.

Requirements:
- Preserve the selected topology and important biological assumptions.
- Mention the target host organism.
- List selected or inferred parts when available.
- Include unresolved risks from the Critic or simulation summary.
- Do not invent experimental validation results.

Output Markdown with these sections:
1. System Architecture
2. Consortia Configuration
3. Biological Constraints
4. Selected Parts
5. Simulation Summary
6. Pending Risks
"""

    topology_to_show = state.best_topology if state.best_topology else (state.current_topology or "")
    simulation_to_show = state.batch_simulation_results or state.simulation_results or {}
    user_content = (
        f"Target host organism:\n{state.host_organism}\n\n"
        f"User intent:\n{state.user_intent}\n\n"
        f"Selected topology:\n{json.dumps(topology_to_show, ensure_ascii=False, indent=2) if isinstance(topology_to_show, dict) else topology_to_show}\n\n"
        f"Critic feedback:\n{state.latest_critic_feedback or ''}\n\n"
        f"Simulation results:\n{json.dumps(simulation_to_show, ensure_ascii=False, indent=2)}"
    )

    state.formal_specification = call_llm(
        api_key,
        model_name,
        system_prompt,
        user_content,
        api_base=api_base,
    )
    return state
