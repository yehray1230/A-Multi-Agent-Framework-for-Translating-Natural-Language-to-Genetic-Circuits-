from __future__ import annotations

import json

from schemas.state import CircuitState
from utils.llm_utils import call_llm


def _build_critic_prompt(state: CircuitState, *, force_zero_shot: bool) -> str:
    system_prompt = f"""You are the Chief Synthetic Biology Decision Maker.

Evaluate the candidate genetic circuit topologies and their ODE simulation summaries.

Target host:
{state.host_organism}

Target intent:
{state.user_intent}

Decision rules:
- PASS only when a candidate is biologically plausible, Cello-mappable, and has acceptable ODE behavior.
- REVISE when logic is incompatible with the intent, Cello mapping is weak, parts look implausible, or simulation results are poor.
- Use `LOGIC_ERROR` when the Boolean/topology design is wrong.
- Use `PART_ERROR` when Cello mapping, UCF selection, or biological part choice is the main issue.
- Use `BOTH` when both logic and parts need changes.
- Use `NONE` only when passing a candidate.
- If a different UCF should be tried, set `recommended_ucf`; otherwise use null.

Output only valid JSON. No Markdown.

Required schema:
{{
  "decision": "PASS",
  "error_type": "NONE",
  "selected_index": 0,
  "recommended_ucf": "Eco1C1G1T1",
  "feedback": "short actionable explanation"
}}
"""

    if force_zero_shot:
        system_prompt += "\nNo RAG context is available; rely on general Cello and synthetic biology principles.\n"
    elif state.rag_context:
        system_prompt += f"\nRetrieved context:\n{state.rag_context}\n"

    return system_prompt


def _build_user_content(state: CircuitState) -> str:
    candidate_topologies = state.candidate_topologies
    batch_simulation_results = state.batch_simulation_results

    if not candidate_topologies or not batch_simulation_results:
        return "ERROR: missing candidate topologies or ODE simulation results."

    sections = []
    for index, (topology, simulation) in enumerate(zip(candidate_topologies, batch_simulation_results)):
        sections.append(
            "=== Candidate Index: {index} ===\n"
            "Topology:\n{topology}\n\n"
            "ODE simulation result:\n{simulation}\n".format(
                index=index,
                topology=json.dumps(topology, ensure_ascii=False, indent=2),
                simulation=json.dumps(simulation, ensure_ascii=False, indent=2),
            )
        )
    return "\n".join(sections)


def call_critic(
    state: CircuitState,
    api_key: str | None,
    model_name: str,
    *,
    api_base: str | None = None,
    force_zero_shot: bool = False,
    max_tool_rounds: int = 3,
) -> CircuitState:
    if not state.batch_simulation_results:
        error_msg = "ERROR: No batch_simulation_results available for Critic to evaluate."
        state.critic_feedbacks.append(error_msg)
        state.is_approved = False
        state.last_error = error_msg
        return state

    system_prompt = _build_critic_prompt(state, force_zero_shot=force_zero_shot)
    user_content = _build_user_content(state)

    max_retries = 3
    for attempt in range(max_retries):
        try:
            raw_response = call_llm(
                api_key=api_key,
                model_name=model_name,
                system_prompt=system_prompt,
                user_content=user_content,
                api_base=api_base,
            )

            cleaned_response = raw_response.strip()
            if cleaned_response.startswith("```json"):
                cleaned_response = cleaned_response[7:]
            if cleaned_response.startswith("```"):
                cleaned_response = cleaned_response[3:]
            if cleaned_response.endswith("```"):
                cleaned_response = cleaned_response[:-3]
            cleaned_response = cleaned_response.strip()

            parsed_json = json.loads(cleaned_response)
            decision = str(parsed_json.get("decision", "REVISE")).upper()
            error_type = str(parsed_json.get("error_type", "NONE")).upper()
            selected_index = parsed_json.get("selected_index")
            recommended_ucf = parsed_json.get("recommended_ucf")
            feedback = parsed_json.get("feedback", "No feedback provided.")

            state.error_type = error_type

            if decision == "PASS" and selected_index is not None:
                state.is_approved = True
                try:
                    state.best_topology = state.candidate_topologies[int(selected_index)]
                except (IndexError, ValueError, TypeError):
                    state.best_topology = None
                    state.is_approved = False
                    error_type = "BOTH"
                    state.error_type = error_type
                    feedback = f"Critic selected invalid candidate index {selected_index}. {feedback}"
                state.critic_feedbacks.append(feedback)
            else:
                state.is_approved = False
                if recommended_ucf:
                    state.critic_feedbacks.append(
                        f"[ROUTE: {decision}] [ERROR: {error_type}] [UCF: {recommended_ucf}] {feedback}"
                    )
                    state.current_ucf = str(recommended_ucf)
                else:
                    state.critic_feedbacks.append(f"[ROUTE: {decision}] [ERROR: {error_type}] {feedback}")

            state.last_error = None
            break

        except json.JSONDecodeError as exc:
            if attempt == max_retries - 1:
                error_msg = f"ERROR: Critic failed to output valid JSON after {max_retries} attempts: {exc}"
                state.critic_feedbacks.append(error_msg)
                state.is_approved = False
                state.last_error = error_msg
            else:
                user_content += (
                    f"\n\nYour last response was not valid JSON ({exc}). "
                    "Return only the required JSON object."
                )
        except Exception as exc:
            error_msg = f"ERROR: critic execution failed: {exc}"
            state.critic_feedbacks.append(error_msg)
            state.is_approved = False
            state.last_error = error_msg
            break

    return state
